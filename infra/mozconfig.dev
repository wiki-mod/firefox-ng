mk_add_options MOZ_OBJDIR=/opt/codex/firefox/builds/dev-obj
mk_add_options "export RUSTC_WRAPPER=/opt/codex/.cargo/bin/sccache"
mk_add_options "export CARGO_INCREMENTAL=0"
ac_add_options --with-ccache=/opt/codex/.cargo/bin/sccache
ac_add_options --enable-debug
ac_add_options --enable-optimize
ac_add_options --disable-tests
mk_add_options AUTOCLOBBER=1
